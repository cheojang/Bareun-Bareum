generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  password         String?           // 이메일 회원가입용 (bcrypt hash). OAuth 유저는 null
  role             String            @default("parent") // "parent" | "therapist"
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  accounts         Account[]
  sessions         Session[]
  children         Child[]
  subscription     Subscription?
  practiceHistory  PracticeSession[]
  therapistProfile Therapist?
  sentMessages     Message[]         @relation("MessageParent")
}

model Child {
  id                    String            @id @default(cuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  image                 String?
  birthDate             DateTime?
  mascotLevel           Int               @default(1)
  totalWords            Int               @default(0)
  totalMinutes          Int               @default(0)
  streakDays            Int               @default(0)
  lastPractice          DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  sessions              PracticeSession[]
  errorRecords          ErrorRecord[]     @relation("ChildErrors")
  weakPhonemes          WeakPhoneme[]     @relation("ChildWeakPhonemes")
  reviewSchedules       ReviewSchedule[]
  savedWords            SavedWord[]
  centerMappings        CenterChild[]
  therapistMappings     TherapistChild[]
  homeworks             Homework[]
  therapyNotes          TherapyNote[]
}

model PracticeSession {
  id          String       @id @default(cuid())
  userId      String
  childId     String
  user        User         @relation(fields: [userId], references: [id])
  child       Child        @relation(fields: [childId], references: [id])
  startedAt   DateTime     @default(now())
  endedAt     DateTime?
  durationMin Int?
  wordRecords WordRecord[]

  // /api/progress, /api/recommendations 등에서 (userId, childId)로 자주 조회
  @@index([userId, childId])
  @@index([childId, startedAt])
}

model WordRecord {
  id            String          @id @default(cuid())
  sessionId     String
  session       PracticeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  targetWord    String
  heardWord     String
  errorPhonemes Json            @default("[]")
  guidanceText  String?
  isCorrect     Boolean         @default(false)
  isBookmarked  Boolean         @default(false)
  practicedAt   DateTime        @default(now())
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  plan             String    @default("free")
  tossCustomerKey  String?   @unique
  tossBillingKey   String?
  status           String    @default("inactive")
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ================== 오답 분석 모델 (ARCHITECT-BRIEF.md) ==================

// ErrorRecord: 부모가 입력한 오답 기록 (Answer Note)
model ErrorRecord {
  id                    String            @id @default(cuid())
  childId               String
  child                 Child             @relation("ChildErrors", fields: [childId], references: [id], onDelete: Cascade)
  targetWord            String            // 목표 단어 (예: "사과")
  childPronunciation    String            // 아이 발음 (예: "따과")
  audioUrl              String?           // 향후 음성 저장용
  errorType             String            // "경음화" | "기음화" | ... (20개 패턴)
  errorCategory         String            // "대치" | "동화" | "탈락" | "첨가"
  errorPattern          String            // 구체적 패턴명
  localAnalysis         LocalAnalysis?
  geminiFeedback        GeminiFeedback?
  reviewSchedule        ReviewSchedule?
  createdAt             DateTime          @default(now())

  @@index([childId, createdAt])
}

// LocalAnalysis: 로컬 자모 분해 분석 결과
model LocalAnalysis {
  id                    String            @id @default(cuid())
  errorRecordId         String            @unique
  errorRecord           ErrorRecord       @relation(fields: [errorRecordId], references: [id], onDelete: Cascade)
  detectedPattern       String            // 탐지된 패턴명 (예: "경음화")
  jamoBreakdown         String            @db.Text // JSON: {"target": [...], "child": [...]}
  confidence            Int               // 신뢰도 (0-100)
  requiresGemini        Boolean           @default(false) // Gemini 필요 여부 (동화 오류 등)
  createdAt             DateTime          @default(now())
}

// GeminiFeedback: Gemini API 응답 결과 (언어치료학적 분석)
model GeminiFeedback {
  id                    String            @id @default(cuid())
  errorRecordId         String            @unique
  errorRecord           ErrorRecord       @relation(fields: [errorRecordId], references: [id], onDelete: Cascade)
  rootCause             String            @db.Text // 원인 설명 (부모 이해 수준, 신체감각 포함)
  trainingStep1         String            @db.Text // 1단계: 조음 감각 깨우기 (방법 + 포인트)
  trainingStep2         String            @db.Text // 2단계: 소리 느끼기
  trainingStep3         String            @db.Text // 3단계: 음절/단어로 연결하기
  trainingStep4         String            @db.Text // 4단계: 문장과 일상에서 적용
  recommendedWords      String            @db.Text // JSON array: ["수박", "소리", "사자", ...] - 같은 음소 포함 단어들
  parentMessage         String            @db.Text @default("") // 부모님을 향한 공감과 격려 메시지
  createdAt             DateTime          @default(now())
}

// WeakPhoneme: 누적 약점 분석 (최근 300개 오답 기준)
model WeakPhoneme {
  id                    String            @id @default(cuid())
  childId               String
  child                 Child             @relation("ChildWeakPhonemes", fields: [childId], references: [id], onDelete: Cascade)
  phoneme               String            // "ㅅ" | "ㄹ" | "ㅂ" etc
  totalAttempts         Int               @default(0) // 최근 300개 중 해당 음소 시도 횟수
  errorCount            Int               @default(0) // 오류 횟수
  errorRate             Float             @default(0) // errorCount / totalAttempts * 100
  weaknessLevel         String            @default("정상범위") // "집중교정필요" | "꾸준한연습필요" | "관찰중" | "정상범위"
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([childId, phoneme])
  @@index([childId])
}

// ReviewSchedule: 망각 곡선 기반 반복 학습 스케줄 (SM-2 알고리즘)
model ReviewSchedule {
  id                    String        @id @default(cuid())
  childId               String
  child                 Child         @relation(fields: [childId], references: [id], onDelete: Cascade)
  errorRecordId         String        @unique
  errorRecord           ErrorRecord   @relation(fields: [errorRecordId], references: [id], onDelete: Cascade)

  targetWord            String        // 목표 단어
  childPronunciation    String        // 오답 발음
  phoneme               String        // 취약 음소 (ㅅ, ㄹ 등)
  errorPattern          String        // 오류 유형 (경음화 등)

  // SM-2 필드
  nextReviewAt          DateTime      @default(now())   // 다음 복습 예정일
  reviewCount           Int           @default(0)       // 총 복습 횟수
  interval              Int           @default(1)       // 현재 간격 (일수)
  easeFactor            Float         @default(2.5)     // 난이도 계수 (1.3~)
  lastReviewedAt        DateTime?                       // 마지막 복습일
  lastQuality           Int?                            // 마지막 품질 점수 (0~5)

  isLearned             Boolean       @default(false)   // 졸업 여부 (5회 이상 성공)

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([childId, nextReviewAt])
}

// PhonemeTemplate: 음소 × 위치 × 오류유형별 미리 생성된 언어치료 훈련 처방전
model PhonemeTemplate {
  id               String   @id @default(cuid())
  phoneme          String   // "ㄹ", "ㅅ", "ㅈ" 등
  position         String   // "초성", "종성", "어중"
  errorType        String   // "탈락", "경음화", "비음화동화" 등
  errorCategory    String   // "탈락", "대치", "동화", "첨가"
  exampleTarget    String   // 예시 목표 단어 "가방"
  exampleChild     String   // 예시 아이 발음 "가바"
  parentHint       String   // 부모 한 줄 힌트
  rootCause        String   @db.Text  // 상세 원인 설명 (~300자)
  trainingStep1    String   @db.Text  // 1단계: 조음 감각
  trainingStep2    String   @db.Text  // 2단계: 소리 느끼기
  trainingStep3    String   @db.Text  // 3단계: 연결하기
  trainingStep4    String   @db.Text  // 4단계: 일상 적용
  recommendedWords String   // JSON array: ["단어1", "단어2", ...]
  generatedAt      DateTime @default(now())

  @@unique([phoneme, position, errorType])
  @@index([phoneme, errorType])
}

// Announcement: 운영자 공지사항 / 업데이트 알림
model Announcement {
  id          String             @id @default(cuid())
  title       String
  content     String             @db.Text
  type        String             @default("notice") // "notice" | "update" | "event"
  isPublished Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  reads       AnnouncementRead[]

  @@index([isPublished, createdAt])
}

// AnnouncementRead: 공지사항 읽음 추적
model AnnouncementRead {
  id             String       @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime     @default(now())
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

// SavedWord: 저장된 단어 (아이연습 완료 후 저장)
model SavedWord {
  id                    String            @id @default(cuid())
  childId               String
  child                 Child             @relation(fields: [childId], references: [id], onDelete: Cascade)
  word                  String
  targetPhoneme         String            // 이 단어로 교정하려는 음소
  difficulty            String            @default("medium") // "easy" | "medium" | "hard"
  savedAt               DateTime          @default(now()) @updatedAt

  @@unique([childId, word])
  @@index([childId])
}

// ================== B2B 언어치료센터 연계 모델 ==================

// Center: 언어치료센터 / 언어상담소
model Center {
  id          String        @id @default(cuid())
  name        String
  phone       String?
  address     String?
  plan        String        @default("basic") // "basic" | "pro"
  inviteCode  String        @unique @default(cuid()) // 부모 연결용 초대코드
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  therapists  Therapist[]
  children    CenterChild[]

  @@index([inviteCode])
}

// Therapist: 치료사 프로필 (User와 1:1, Center 소속)
// role: 센터 내 역할 — "owner"(상담소장, 센터 설정 권한) | "staff"(일반 상담사)
model Therapist {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  centerId  String
  center    Center           @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name      String
  role      String           @default("staff") // "owner" | "staff"
  license   String?          // 언어재활사 자격증 번호
  phone     String?
  createdAt DateTime         @default(now())
  children  TherapistChild[]
  homeworks Homework[]
  notes     TherapyNote[]
  messages  Message[]        @relation("MessageTherapist")

  @@index([centerId])
}

// CenterChild: 센터 ↔ 아이 연결 (부모가 초대코드로 등록)
model CenterChild {
  centerId   String
  childId    String
  enrolledAt DateTime @default(now())
  center     Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  child      Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@id([centerId, childId])
  @@index([centerId])
}

// TherapistChild: 치료사 ↔ 아이 담당 배정
model TherapistChild {
  therapistId String
  childId     String
  assignedAt  DateTime  @default(now())
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  child       Child     @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@id([therapistId, childId])
  @@index([therapistId])
}

// Homework: 치료사가 아이에게 배정한 숙제
model Homework {
  id            String      @id @default(cuid())
  therapistId   String
  childId       String
  targetWords   String      // JSON: ["사과","수박","소방차"]
  targetPhoneme String?     // "ㅅ"
  description   String?     // 메모
  dueDate       DateTime
  status        String      @default("pending") // "pending" | "done"
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  therapist     Therapist   @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  child         Child       @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, dueDate])
  @@index([therapistId])
}

// TherapyNote: 회기별 치료 일지
model TherapyNote {
  id                String    @id @default(cuid())
  therapistId       String
  childId           String
  sessionDate       DateTime
  targetPhonemes    String    // JSON: ["ㅅ","ㄹ"]
  performance       Int       // 0~100 수행도
  memo              String    @db.Text
  isVisibleToParent Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  therapist         Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  child             Child     @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, sessionDate])
  @@index([therapistId])
}

// WordPairCache: 글로벌 단어쌍 캐시 — 동일 (목표단어+아이발음) 재분석 시 Gemini 호출 없이 즉시 반환
model WordPairCache {
  id                 String   @id @default(cuid())
  targetWord         String
  childPronunciation String
  errorType          String
  errorCategory      String
  rootCause          String   @db.Text
  trainingStep1      String   @db.Text
  trainingStep2      String   @db.Text
  trainingStep3      String   @db.Text
  trainingStep4      String   @db.Text
  recommendedWords   String   // JSON array
  parentMessage      String   @db.Text
  hitCount           Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([targetWord, childPronunciation])
  @@index([hitCount])
}

// GuestUsage: 비회원(게스트) 월간 AI 호출 카운터 — IP 해시 기반 서버측 저장 (쿠키 변조 우회 방지)
model GuestUsage {
  id        String   @id @default(cuid())
  ipHash    String
  month     String   // "YYYY-MM"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([ipHash, month])
  @@index([month])
}

// Message: 부모 ↔ 치료사 1:1 메시지
model Message {
  id          String    @id @default(cuid())
  therapistId String
  parentId    String
  childId     String
  content     String    @db.Text
  senderRole  String    // "therapist" | "parent"
  isRead      Boolean   @default(false)
  sentAt      DateTime  @default(now())
  therapist   Therapist @relation("MessageTherapist", fields: [therapistId], references: [id], onDelete: Cascade)
  parent      User      @relation("MessageParent", fields: [parentId], references: [id], onDelete: Cascade)

  @@index([therapistId, parentId, sentAt])
  @@index([parentId])
}
