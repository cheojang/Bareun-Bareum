# ===== 바른발음 환경 변수 설정 =====
# 이 파일을 복사하여 .env.local 파일을 만들고 실제 값을 입력하세요
# cp .env.example .env.local

# ---- Database ----
# PostgreSQL 연결 문자열 (Supabase / Neon / Railway 등)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bareunbareum?schema=public"

# ---- NextAuth ----
# 랜덤 비밀키 생성: openssl rand -base64 32
AUTH_SECRET="your-random-secret-key"
# 로컬: http://localhost:3000 / 프로덕션: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth ----
# https://console.cloud.google.com/apis/credentials 에서 생성
# 승인된 리디렉션 URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ---- Kakao OAuth ----
# https://developers.kakao.com/ 에서 앱 생성
# 카카오 로그인 → Redirect URI: {NEXTAUTH_URL}/api/auth/callback/kakao
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# ---- Gemini AI ----
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY="your-gemini-api-key"

# ---- TossPayments ----
# https://developers.tosspayments.com/ 에서 발급
# 테스트 키: test_ck_... / test_sk_...  |  실결제 키: live_ck_... / live_sk_...
NEXT_PUBLIC_TOSS_CLIENT_KEY="test_ck_your_client_key"
TOSS_SECRET_KEY="test_sk_your_secret_key"

# ---- Resend (이메일 인증) ----
# https://resend.com/api-keys 에서 발급
RESEND_API_KEY="re_your_resend_api_key"
# 발신자 주소 (Resend에서 인증된 도메인 필요)
RESEND_FROM="바른발음 <noreply@yourdomain.com>"

# ---- 관리자 (선택) ----
# 쉼표로 구분된 관리자 이메일 목록
ADMIN_EMAILS="admin@yourdomain.com"

# ---- 개발자 로그인 (선택, 로컬 전용) ----
# 1로 설정하면 /login에서 dev@test.com 등 테스트 계정 사용 가능.
# 프로덕션에는 절대 1로 설정하지 말 것. NODE_ENV=development일 때만 동작함.
ALLOW_DEV_LOGIN="0"

# ---- Supabase Storage (아이 사진 저장) ----
# https://supabase.com/dashboard → 프로젝트 Settings → API 에서 확인
# URL: Project URL (예: https://xxxx.supabase.co)
SUPABASE_URL="https://your-project-id.supabase.co"
# Service Role Key: 비공개 — 서버사이드 전용, 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
